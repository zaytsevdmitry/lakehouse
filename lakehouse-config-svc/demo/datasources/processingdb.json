{
  "keyName": "processingdb",
  "driverKeyName":"postgres",
  "service":
    {
      "host": "localhost",
      "port": "5432",
      "urn": "postgresDB",
      "properties": {
        "password": "postgresPW",
        "user": "postgresUser",
        "fetchSize": "10000",
        "spark.sql.catalog.processingdb": "org.apache.spark.sql.execution.datasources.v2.jdbc.JDBCTableCatalog",
        "spark.sql.catalog.processingdb.url": "{{driver.connectionTemplates['jdbc']}}",
        "spark.sql.catalog.processingdb.user": "{{driver.services[0].properties['user']}}",
        "spark.sql.catalog.processingdb.password": "{{driver.services[0].properties['password']}}",
        "spark.sql.catalog.processingdb.type": "hive"

      }
    },
  "description": "Remote datastore processingdb"
}


